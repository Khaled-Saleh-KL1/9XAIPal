# Celery-worker image WITH MinerU for high-fidelity PDF extraction (layout, OCR,
# table-structure recognition, equation -> LaTeX). Same uv-driven, lockfile-based
# dependency install as the API image (Dockerfile), plus the OpenCV/runtime
# shared libs MinerU's models load and the pre-downloaded pipeline models.
#
# CPU-only: Docker on Apple Silicon has no GPU passthrough, so extraction is
# CPU-bound. Only the worker extracts PDFs (via the process_ingestion task).

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    # The locked torch pulls in multi-hundred-MB CUDA wheels. The default 30s
    # HTTP timeout aborts mid-download on a slow link, so raise it and cap how
    # many huge wheels download in parallel (so each gets enough bandwidth).
    UV_HTTP_TIMEOUT=600 \
    UV_CONCURRENT_DOWNLOADS=4 \
    MINERU_MODEL_SOURCE=huggingface \
    HF_HUB_DISABLE_TELEMETRY=1 \
    # Signal to mineru_client.py that the pipeline models are pre-baked into
    # this image (see the `mineru-models-download` step below). When this is
    # set the orchestrator leaves HF_HUB_OFFLINE unset, which is required
    # because MinerU's post-processing stage reuses the HF HTTP client and
    # would otherwise surface as "All connection attempts failed" when it
    # tries to reach the optional LLM-aided VLM endpoint.
    MINERU_BAKED_INTO_IMAGE=1

WORKDIR /app

# uv binary, pinned to the same version that produced the lockfile.
COPY --from=ghcr.io/astral-sh/uv:0.10.8 /uv /uvx /bin/

# System deps: build tools + libpq + the OpenCV/runtime libs MinerU loads at
# import time (libGL, glib, OpenMP).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        curl \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install the full locked dependency set (incl. mineru + torch) with uv. The
# shared cache mount means torch/mineru are pulled from uv's cache (already
# populated by the API image build) instead of re-downloading.
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-dev --no-emit-project -o /tmp/requirements.lock \
 && uv pip install --system \
      --extra-index-url https://download.pytorch.org/whl/cpu \
      --index-strategy unsafe-best-match \
      -r /tmp/requirements.lock

# Pre-download the pipeline models INTO the image so the first upload doesn't
# stall on a multi-GB download. Non-interactive (both -s and -m supplied).
# Baked into the image layer — no volume to shadow it.
RUN mineru-models-download -s huggingface -m pipeline

# Patch MinerU's CLI HTTP timeout (default read=60s) so long-running
# extractions (large books, 500+ pages) don't trip a 60s polling timeout
# and surface as "All connection attempts failed". The CLI is a thin client
# over a local FastAPI server; the server keeps working fine, but the
# client's `read=60` kills each poll before the server can respond. Bumping
# to 30 minutes makes polling patient enough for books. The `sed` is
# idempotent and pinned to a specific source path so a MinerU upgrade that
# changes the function signature will surface as a build failure rather
# than a silent regression.
RUN MINERU_API_CLIENT=$(python -c "import mineru.cli.api_client, os; print(os.path.abspath(mineru.cli.api_client.__file__))") && \
    sed -i 's/return httpx.Timeout(connect=10, read=60, write=300, pool=30)/return httpx.Timeout(connect=10, read=1800, write=600, pool=60)/' "$MINERU_API_CLIENT" && \
    echo "Patched MinerU HTTP timeout in $MINERU_API_CLIENT:" && \
    grep -n "httpx.Timeout" "$MINERU_API_CLIENT" | head -3

COPY app ./app

# Compose overrides this, but default to the worker so the image is self-describing.
CMD ["celery", "-A", "app.core.celery_app", "worker", "--loglevel=info"]
