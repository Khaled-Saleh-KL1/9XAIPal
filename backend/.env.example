# 9XAIPal Backend - Local Development
# Copy this file to .env and fill in your own values.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=9xaipal
POSTGRES_USER=9xaipal
POSTGRES_PASSWORD=9xaipal_dev_password
STORAGE_ROOT=app/storage

# ── Ollama (local backend) ──────────────────────────────────────────────────
# These models are used whenever Ollama is the active backend.
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=
# Vision model for figure descriptions / image questions. Empty = reuse CHAT_MODEL.
VLM_MODEL=
EMBEDDING_MODEL=
# Max characters of a chunk sent to the embedder (Ollama 400s on over-window
# inputs; ~3000 is safe locally — cloud embedders can take much more).
EMBED_MAX_CHARS=3000
# Stored embedding dimension. Larger model outputs are truncated+renormalized
# (MRL), smaller ones zero-padded. Keep ≤ 2000 so the pgvector HNSW index can
# exist (default 1024). Changing this re-embeds the whole library on next start.
VECTOR_DIMENSION=1024
SEARXNG_URL=http://localhost:8080
DEBUG=true

# ── AI backend selection (local Ollama or cloud APIs) ─────────────────────
# auto (default) = use Ollama when it is reachable at OLLAMA_BASE_URL;
# otherwise fall back to the first cloud API key below, in this order:
# OpenAI → Anthropic → Gemini → xAI → DeepSeek. If neither Ollama nor a key
# is available, the app answers with clear instructions to add one.
# Pin a backend explicitly with: ollama | openai | anthropic | gemini | xai |
# deepseek | custom (any OpenAI-compatible endpoint via LLM_BASE_URL).
LLM_PROVIDER=auto
# Generic key for a pinned LLM_PROVIDER; the per-provider keys below also work.
LLM_API_KEY=
# Only needed for LLM_PROVIDER=custom (e.g. OpenRouter, vLLM, llama.cpp
# server) or to override a provider's default URL.
LLM_BASE_URL=

# Per-provider API keys — paste any you have; in auto mode the first one
# found (in the order above) is used when Ollama is off.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Models used when a cloud provider is active (defaults shown — uncomment to
# change). CHAT_MODEL / VLM_MODEL / CLASSIFIER_MODEL above stay reserved for
# Ollama (and "custom"), so an Ollama tag is never sent to a cloud API.
# OPENAI_CHAT_MODEL=gpt-4o
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# XAI_CHAT_MODEL=grok-4
# DEEPSEEK_CHAT_MODEL=deepseek-chat   # no vision: figure images can't be described
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Turn on reasoning/thinking mode for OpenAI o-series models (o1, o3-mini,
# o4-mini, etc.) and custom OpenAI-compatible endpoints that support it.
# Ignored for Anthropic, Gemini, xAI, DeepSeek, and Ollama.
CLOUD_THINKING_MODE=false

# Embeddings follow the same auto chain, but only OpenAI and Gemini offer
# embedding APIs (Anthropic/xAI/DeepSeek have none). Pin it (e.g.
# EMBEDDING_PROVIDER=openai) when switching to cloud permanently — stale
# vectors are then wiped and the library re-embeds automatically on startup.
# Key/base-url fall back to LLM_API_KEY / LLM_BASE_URL when empty.
EMBEDDING_PROVIDER=auto
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# ── Security ──────────────────────────────────────────────────────────────
# Browser origins allowed to call the API (comma-separated). Add your LAN
# address (e.g. http://192.168.1.50:5173) when other machines use the dev UI.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Per-client-IP request ceiling per minute across /api routes. 0 disables.
RATE_LIMIT_PER_MINUTE=300

# ── Latency tuning ────────────────────────────────────────────────────────
# Small model (e.g. llama3.2:3b) for router/guardrail classification — the
# single biggest /ask speedup. Empty = reuse CHAT_MODEL.
CLASSIFIER_MODEL=
# Keep models resident in memory between requests ("30m", "-1" = forever).
OLLAMA_KEEP_ALIVE=30m
# Max concurrent /ask requests per uvicorn worker (protects Ollama from OOM).
MAX_CONCURRENT_ASKS=3

# Ollama runtime - use this when starting ollama:
# OLLAMA_FLASH_ATTENTION=0 ollama serve
# OLLAMA_FLASH_ATTENTION=0

# HuggingFace auth — used by MinerU to download model weights from HF Hub.
# huggingface_hub reads HUGGING_FACE_HUB_TOKEN / HF_TOKEN automatically.
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
